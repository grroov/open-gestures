{
   "action": { 
      "default_icon": "assets/icon.png",
      "default_title": "Open Gestures Options",
      "default_popup": "options.html"
   },
   "background": { "service_worker": "background.js" },
   "options_ui": {
      "page": "options.html",
      "open_in_tab": false
   },
   "content_scripts": [{
      "all_frames": true,
      "js": [ "gestures.js" ],
      "matches": [ "<all_urls>" ],
      "run_at": "document_start"
   }],
   "description": "Super minimal and fast middle button mouse gestures!",
   "icons": { "128": "assets/icon.png" },
   "manifest_version": 3,
   "name": "Open Gestures",
   "permissions": [ "tabs", "storage" ],
   "version": "2026.2.0"
   }